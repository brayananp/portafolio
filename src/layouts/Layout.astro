---
import deferredFonts from "../styles/deferred-fonts.css?url";
import "../styles/fonts.css";
import "../styles/global.css";
import AmbientBackground from "../components/AmbientBackground.astro";
import RevealOnScroll from "../components/RevealOnScroll.astro";
import Seo from "../components/Seo.astro";
import { getSiteUrl } from "../lib/seo";
import type { Locale } from "../types/portfolio";

interface Props {
	title: string;
	description?: string;
	lang: Locale;
	path?: string;
	image?: string;
	imageAlt?: string;
	ogType?: "website" | "article" | "profile";
	publishedAt?: Date;
	modifiedAt?: Date;
	authorName?: string;
	noindex?: boolean;
	alternatePath?: string;
	jsonLd?: Record<string, unknown>[];
}

const {
	title,
	description,
	lang,
	path,
	image,
	imageAlt,
	ogType,
	publishedAt,
	modifiedAt,
	authorName,
	noindex,
	alternatePath,
	jsonLd,
} = Astro.props;

const alternateLang = lang === "es" ? "en" : "es";
const siteUrl = getSiteUrl(Astro.site);
const currentPath = path ?? `/${lang}`;
const canonicalUrl = siteUrl ? `${siteUrl}${currentPath}` : currentPath;
const isBlogArticle = /^\/(es|en)\/blog\/.+/.test(currentPath);
const resolvedAlternatePath =
	alternatePath ??
	(isBlogArticle
		? `/${alternateLang}/blog`
		: currentPath.replace(`/${lang}`, `/${alternateLang}`));
const alternateUrl = siteUrl
	? `${siteUrl}${resolvedAlternatePath}`
	: resolvedAlternatePath;

const umamiSrc = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;


---

<!doctype html>
<html lang={lang} data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link
			rel="stylesheet"
			href={deferredFonts}
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link rel="stylesheet" href={deferredFonts} />
		</noscript>
		<slot name="head" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<Seo
			title={title}
			description={description}
			lang={lang}
			path={currentPath}
			canonicalUrl={canonicalUrl}
			alternateUrl={alternateUrl}
			siteUrl={siteUrl}
			image={image}
			imageAlt={imageAlt}
			ogType={ogType}
			publishedAt={publishedAt}
			modifiedAt={modifiedAt}
			authorName={authorName}
			noindex={noindex}
			jsonLd={jsonLd}
		/>
		<script is:inline>
			(() => {
				const stored = localStorage.getItem("theme");
				const theme = stored === "light" || stored === "dark" ? stored : "dark";
				document.documentElement.setAttribute("data-theme", theme);
			})();
		</script>
		{
			umamiSrc && umamiWebsiteId && (
			  <script
				is:inline
				define:vars={{ umamiSrc, umamiWebsiteId }}
			  >
				{`
				// Cargamos Umami de forma totalmente asíncrona y fuera del camino
				// crítico: si el servidor tarda o no responde, no bloquea ni retrasa
				// el resto de scripts ni la interactividad de la página.
				(function () {
				  function loadUmami() {
					var s = document.createElement('script');
					s.src = umamiSrc;
					s.async = true;
					s.setAttribute('data-website-id', umamiWebsiteId);
					s.onerror = function () { s.remove(); };
					document.head.appendChild(s);
				  }
				  if (document.readyState === 'complete') {
					loadUmami();
				  } else {
					window.addEventListener('load', loadUmami);
				  }
				})();
				`}
			  </script>
			)
		  }
	</head>
	<body class="bg-bg text-primary antialiased relative isolate">
		<AmbientBackground />
		<div class="relative z-10">
			<slot />
		</div>
		<RevealOnScroll />
		<link rel="manifest" href="/site.webmanifest" />
	</body>
</html>
