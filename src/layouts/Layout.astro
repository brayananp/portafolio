---
import deferredFonts from "../styles/deferred-fonts.css?url";
import "../styles/fonts.css";
import "../styles/global.css";
import AmbientBackground from "../components/AmbientBackground.astro";
import RevealOnScroll from "../components/RevealOnScroll.astro";
import Seo from "../components/Seo.astro";
import { getSiteUrl } from "../lib/seo";
import type { Locale } from "../types/portfolio";

interface Props {
	title: string;
	description?: string;
	lang: Locale;
	path?: string;
	image?: string;
	imageAlt?: string;
	ogType?: "website" | "article" | "profile";
	publishedAt?: Date;
	modifiedAt?: Date;
	authorName?: string;
	noindex?: boolean;
	alternatePath?: string;
	jsonLd?: Record<string, unknown>[];
}

const {
	title,
	description,
	lang,
	path,
	image,
	imageAlt,
	ogType,
	publishedAt,
	modifiedAt,
	authorName,
	noindex,
	alternatePath,
	jsonLd,
} = Astro.props;

const alternateLang = lang === "es" ? "en" : "es";
const siteUrl = getSiteUrl(Astro.site);
const currentPath = path ?? `/${lang}`;
const canonicalUrl = siteUrl ? `${siteUrl}${currentPath}` : currentPath;
const isBlogArticle = /^\/(es|en)\/blog\/.+/.test(currentPath);
const resolvedAlternatePath =
	alternatePath ??
	(isBlogArticle
		? `/${alternateLang}/blog`
		: currentPath.replace(`/${lang}`, `/${alternateLang}`));
const alternateUrl = siteUrl
	? `${siteUrl}${resolvedAlternatePath}`
	: resolvedAlternatePath;

---

<!doctype html>
<html lang={lang} data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preload" href={deferredFonts} as="style" />
		<link rel="stylesheet" href={deferredFonts} />
		<slot name="head" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<Seo
			title={title}
			description={description}
			lang={lang}
			path={currentPath}
			canonicalUrl={canonicalUrl}
			alternateUrl={alternateUrl}
			siteUrl={siteUrl}
			image={image}
			imageAlt={imageAlt}
			ogType={ogType}
			publishedAt={publishedAt}
			modifiedAt={modifiedAt}
			authorName={authorName}
			noindex={noindex}
			jsonLd={jsonLd}
		/>
		<script is:inline src="/theme-init.js"></script>
		<script defer src="https://cloud.umami.is/script.js" data-website-id="98817b9d-d3f6-469a-8547-f5744cfca16e"></script>
	</head>
	<body class="bg-bg text-primary antialiased relative isolate">
		<AmbientBackground />
		<div class="relative z-10">
			<slot />
		</div>
		<RevealOnScroll />
		<link rel="manifest" href="/site.webmanifest" />
	</body>
</html>
