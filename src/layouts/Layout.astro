---
import "@fontsource-variable/inter";
import "@fontsource/jetbrains-mono";
import "../styles/global.css";
import AmbientBackground from "../components/AmbientBackground.astro";
import RevealOnScroll from "../components/RevealOnScroll.astro";
import type { Locale } from "../types/portfolio";
import { extractProjectIdFromPath } from "../lib/projects";

interface Props {
	title: string;
	description?: string;
	lang: Locale;
	path?: string;
}

const { title, description, lang, path } = Astro.props;
const alternateLang = lang === "es" ? "en" : "es";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const currentPath = path ?? `/${lang}`;
const canonicalUrl = siteUrl ? `${siteUrl}${currentPath}` : currentPath;
const isBlogArticle = /^\/(es|en)\/blog\/.+/.test(currentPath);
const projectId = extractProjectIdFromPath(currentPath);
const isProjectPage = projectId !== null;
const alternatePath = isBlogArticle
	? `/${alternateLang}/blog`
	: isProjectPage
		? `/${alternateLang}/projects/${projectId}`
		: currentPath.replace(`/${lang}`, `/${alternateLang}`);
const alternateUrl = siteUrl ? `${siteUrl}${alternatePath}` : alternatePath;
---

<!doctype html>
<html lang={lang} data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{siteUrl && (
			<>
				<link rel="canonical" href={canonicalUrl} />
				<link rel="alternate" hreflang={lang} href={canonicalUrl} />
				<link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
				<link rel="alternate" hreflang="x-default" href={`${siteUrl}/es`} />
			</>
		)}
		<script is:inline>
			(() => {
				const stored = localStorage.getItem("theme");
				const theme = stored === "light" || stored === "dark" ? stored : "dark";
				document.documentElement.setAttribute("data-theme", theme);
			})();
		</script>
	</head>
	<body class="bg-bg text-primary antialiased relative isolate">
		<AmbientBackground />
		<div class="relative z-10">
			<slot />
		</div>
		<RevealOnScroll />
	</body>
</html>
