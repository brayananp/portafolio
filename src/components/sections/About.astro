---
import type { UiKey } from "../../i18n/ui";
import type { PortfolioData } from "../../types/portfolio";

interface Props {
	data: PortfolioData["about"];
	t: (key: UiKey) => string;
}

const { data, t } = Astro.props;
const paragraphs = data.paragraphs ?? [data.content];
---

<section id="about" class="px-6">
	<div class="max-w-4xl mx-auto">
		<span
			class="inline-block font-mono text-xs text-amber bg-amber-bg px-2.5 py-0.5 rounded-md"
		>
			{t("about.badge")}
		</span>
		<h2 class="font-display font-medium text-2xl mt-3 mb-4 text-primary">
			{t("about.title")}
		</h2>
		<div class="max-w-3xl space-y-5">
			{paragraphs.map((paragraph) => (
				<p class="text-secondary leading-relaxed text-[15px] sm:text-base">
					{paragraph}
				</p>
			))}
		</div>
	</div>
</section>
