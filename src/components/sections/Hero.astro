---
 import { Image } from "astro:assets";
 import avatarSrc from "../../assets/images/avatar.webp";
 import GithubIcon from "../../icons/GithubIcon.astro";
 import LinkedinIcon from "../../icons/LinkedinIcon.astro";
 import type { UiKey } from "../../i18n/ui";
 import type { Locale, PortfolioData } from "../../types/portfolio";

interface Props {
	data: PortfolioData["hero"];
 	social: PortfolioData["social"];
	displayName: string;
	lang: Locale;
	t: (key: UiKey) => string;
}

 const { data, social, displayName, lang, t } = Astro.props;

const formattedDate = new Date(data.releaseDate).toLocaleDateString(
	lang === "en" ? "en-US" : "es-PE",
	{ year: "numeric", month: "long", day: "numeric" },
);
---

<section id="hero" class="pt-24 px-6">
	<div class="max-w-4xl mx-auto">
		<span
			class="inline-block font-mono text-xs text-amber bg-amber-bg px-2.5 py-0.5 rounded-md"
		>
			{t("hero.badge")}
		</span>

		<div class="mt-6 flex flex-col-reverse sm:flex-row sm:items-start gap-6 sm:gap-10">
			<div class="flex-1 min-w-0">
				<h1 class="font-display font-medium text-4xl sm:text-5xl text-primary leading-tight">
					{displayName}
				</h1>

				<div class="mt-3 flex items-center gap-2 flex-wrap font-mono text-sm">
					<span class="text-amber">{data.version}</span>
					<span class="text-muted" aria-hidden="true">·</span>
					<span class="text-secondary">{data.role}</span>
				</div>

				<p class="mt-4 text-secondary text-base max-w-2xl leading-relaxed">
					{data.tagline}
				</p>

				<div class="mt-6 font-mono text-xs text-muted">
					<span class="text-amber">{t("hero.releaseDate")}:</span>
					<time datetime={data.releaseDate}>{formattedDate}</time>
				</div>

				<div class="mt-6 flex flex-wrap items-center gap-4 font-mono text-sm">
					<a
						href={social.github}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={t("contact.github")}
						class="inline-flex items-center gap-1.5 text-secondary hover:text-amber transition-colors"
					>
						<GithubIcon class="shrink-0" aria-hidden="true" />
						<span>{t("contact.github")}</span>
					</a>

					<a
						href={social.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={t("contact.linkedin")}
						class="inline-flex items-center gap-1.5 text-secondary hover:text-amber transition-colors"
					>
						<LinkedinIcon class="shrink-0" aria-hidden="true" />
						<span>{t("contact.linkedin")}</span>
					</a>
				</div>
			</div>

			<div class="shrink-0 self-center sm:self-start sm:mt-1">
				<Image
					src={avatarSrc}
					alt={data.avatar.alt}
					width={176}
					height={176}
					widths={[144, 176, 288, 352]}
					sizes="(max-width: 640px) 144px, 176px"
					quality={80}
					format="webp"
					class="size-36 sm:size-44 rounded-2xl border border-border ring-2 ring-amber/15 object-cover object-top bg-surface-1"
					loading="eager"
					fetchpriority="high"
					decoding="async"
				/>
			</div>
		</div>
	</div>
</section>
