---
import type { UiKey } from "../../i18n/ui";
import {
	formatBlogDate,
	getBlogPostPath,
	getPublishedBlogPosts,
	getSlugFromPostId,
} from "../../lib/blog";
import { getLocalizedPath } from "../../i18n/utils";
import { changeTypeConfig } from "../../lib/changeTypeConfig";
import type { Locale } from "../../types/portfolio";

interface Props {
	lang: Locale;
	t: (key: UiKey) => string;
}

const { lang, t } = Astro.props;
const posts = (await getPublishedBlogPosts(lang)).slice(0, 3);
const blogIndexPath = getLocalizedPath("/blog", lang);
---

<section id="blog" class="px-6">
	<div class="max-w-4xl mx-auto">
		<span
			class="inline-block font-mono text-xs text-amber bg-amber-bg px-2.5 py-0.5 rounded-md"
		>
			{t("blog.badge")}
		</span>
		<h2 class="font-display font-medium text-2xl mt-3 mb-4 text-primary">
			{t("blog.title")}
		</h2>

		{
			posts.length > 0 ? (
				<div class="space-y-1 mb-6">
					{posts.map((post) => {
						const slug = getSlugFromPostId(post.id);
						const config = changeTypeConfig[post.data.changeType];
						const formattedDate = formatBlogDate(
							post.data.publishedAt,
							lang,
						);

						return (
							<a
								href={getBlogPostPath(lang, slug)}
								class="group flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 py-3 border-b border-border/60 hover:bg-surface-hover/50 -mx-3 px-3 rounded-lg transition-colors"
							>
								<div class="font-mono text-xs flex items-center gap-3 shrink-0">
									{post.data.version && (
										<span class="text-amber">{post.data.version}</span>
									)}
									<span class={config.className}>
										{config.symbol} {config.label}
									</span>
									<time
										datetime={post.data.publishedAt.toISOString()}
										class="text-muted hidden sm:inline"
									>
										{formattedDate}
									</time>
								</div>
								<span class="font-display font-medium text-primary group-hover:text-amber transition-colors">
									{post.data.title}
								</span>
							</a>
						);
					})}
				</div>
			) : (
				<p class="text-secondary text-sm leading-relaxed max-w-2xl mb-6">
					{t("blog.noPosts")}
				</p>
			)
		}

		<a
			href={blogIndexPath}
			class="inline-flex items-center gap-1.5 font-mono text-xs text-amber hover:underline"
		>
			{t("blog.viewAll")}
			<span aria-hidden="true">→</span>
		</a>
	</div>
</section>
