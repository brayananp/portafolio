---
import type { UiKey } from "../../i18n/ui";
import type { PortfolioData } from "../../types/portfolio";

interface Props {
	data: PortfolioData;
	t: (key: UiKey) => string;
}

const { data, t } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="px-6 pt-8 pb-12">
	<div class="max-w-4xl mx-auto">
		{
			data.isPlaceholder && (
				<p class="font-mono text-xs text-amber bg-amber-bg px-3 py-2 rounded-md mb-6">
					{t("footer.placeholder")}
				</p>
			)
		}

		<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
			<button
				type="button"
				disabled
				class="font-mono text-xs text-muted border border-border rounded-md px-4 py-2 cursor-not-allowed opacity-60"
				aria-disabled="true"
				title={t("footer.comingSoon")}
			>
				{t("footer.exportCv")} — {t("footer.comingSoon")}
			</button>

			<div class="flex items-center gap-4">
				<a
					href={data.social.github}
					target="_blank"
					rel="noopener noreferrer"
					class="font-mono text-xs text-secondary hover:text-primary transition-colors"
				>
					GitHub
				</a>
				<a
					href={data.social.linkedin}
					target="_blank"
					rel="noopener noreferrer"
					class="font-mono text-xs text-secondary hover:text-primary transition-colors"
				>
					LinkedIn
				</a>
			</div>
		</div>

		<p class="mt-6 font-mono text-[11px] text-muted">
			© {currentYear} {data.authorName} · MIT License
		</p>
	</div>
</footer>
