---
import type { UiKey } from "../../i18n/ui";
import type { Locale, PortfolioData } from "../../types/portfolio";
import ExportCvButton from "../ExportCvButton.astro";

interface Props {
	data: PortfolioData;
	lang: Locale;
	t: (key: UiKey) => string;
}

const { data, lang, t } = Astro.props;
const currentYear = new Date().getFullYear();
const licenseUrl = `${data.social.github}/blob/master/LICENSE`;
---

<footer class="px-6 pt-8 pb-12">
	<div class="max-w-4xl mx-auto">
		<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
			<ExportCvButton portfolio={data} lang={lang} t={t} />

			<div class="flex items-center gap-4">
				<a
					href={data.social.github}
					target="_blank"
					rel="noopener noreferrer"
					class="font-mono text-xs text-secondary hover:text-primary transition-colors"
				>
					GitHub
				</a>
				<a
					href={data.social.linkedin}
					target="_blank"
					rel="noopener noreferrer"
					class="font-mono text-xs text-secondary hover:text-primary transition-colors"
				>
					LinkedIn
				</a>
			</div>
		</div>

		<p class="mt-6 font-mono text-[11px] text-muted">
			© {currentYear} {data.displayName}  ·{" "} 
			<a
				href={licenseUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="hover:text-amber transition-colors"
			>
				{t("footer.license")}
			</a>
			{" · "}
			{t("footer.builtWith")} <span class="text-amber hover:text-primary transition-colors">❤️</span>
		</p>
	</div>
</footer>
