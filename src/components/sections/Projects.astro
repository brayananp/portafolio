---
import type { UiKey } from "../../i18n/ui";
import type { Locale, PortfolioData } from "../../types/portfolio";
import ProjectCard from "../projects/ProjectCard.astro";

interface Props {
	data: PortfolioData["projects"];
	lang: Locale;
	t: (key: UiKey) => string;
}

const { data, lang, t } = Astro.props;
---

<section id="projects" class="px-6 scroll-mt-28">
	<div class="max-w-4xl mx-auto">
		<div data-reveal>
			<span
				class="inline-block font-mono text-xs text-amber bg-amber-bg px-2.5 py-0.5 rounded-md"
			>
				{t("projects.badge")}
			</span>
			<h2 class="font-display font-medium text-2xl mt-3 mb-2 text-primary">
				{t("projects.title")}
			</h2>
			<p class="text-secondary text-sm max-w-2xl mb-8 leading-relaxed">
				{t("projects.subtitle")}
			</p>
		</div>

		<div class="grid gap-4 sm:grid-cols-2">
			{data.map((project, index) => (
				<ProjectCard project={project} lang={lang} t={t} index={index} />
			))}
		</div>
	</div>
</section>
