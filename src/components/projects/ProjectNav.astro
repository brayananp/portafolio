---
import type { UiKey } from "../../i18n/ui";
import { getAdjacentProjects, getProjectPath } from "../../lib/projects";
import type { Locale, Project } from "../../types/portfolio";

interface Props {
	currentProject: Project;
	lang: Locale;
	t: (key: UiKey) => string;
}

const { currentProject, lang, t } = Astro.props;
const { previous, next } = getAdjacentProjects(lang, currentProject.id);

if (!previous && !next) return;
---

<nav
	class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row gap-4 sm:justify-between"
	aria-label={t("projects.navigation")}
	data-reveal
	data-reveal-delay="320"
>
	{
		previous ? (
			<a
				href={getProjectPath(lang, previous.id)}
				class="group flex-1 rounded-xl border border-border bg-surface/50 px-4 py-3 hover:border-amber/40 hover:bg-surface-hover transition-colors"
			>
				<span class="font-mono text-[11px] text-muted block mb-1">
					← {t("projects.previous")}
				</span>
				<span class="font-display text-primary group-hover:text-amber transition-colors">
					{previous.name}
				</span>
			</a>
		) : (
			<div class="flex-1" />
		)
	}
	{
		next ? (
			<a
				href={getProjectPath(lang, next.id)}
				class="group flex-1 rounded-xl border border-border bg-surface/50 px-4 py-3 hover:border-amber/40 hover:bg-surface-hover transition-colors sm:text-right"
			>
				<span class="font-mono text-[11px] text-muted block mb-1">
					{t("projects.next")} →
				</span>
				<span class="font-display text-primary group-hover:text-amber transition-colors">
					{next.name}
				</span>
			</a>
		) : (
			<div class="flex-1" />
		)
	}
</nav>
