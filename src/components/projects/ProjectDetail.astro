---
import type { UiKey } from "../../i18n/ui";
import { getLocalizedPath } from "../../i18n/utils";
import type { Locale, Project } from "../../types/portfolio";
import Header from "../Header.astro";
import ProjectNav from "./ProjectNav.astro";

interface Props {
	project: Project;
	lang: Locale;
	t: (key: UiKey) => string;
}

const { project, lang, t } = Astro.props;
const homePath = getLocalizedPath("/", lang);
const projectsHref = `${homePath}#projects`;
const hasLinks = Boolean(project.links?.demo || project.links?.repo);
---

<Header lang={lang} />
<main class="px-6 pt-28 pb-16">
	<article class="max-w-3xl mx-auto">
		<a
			href={projectsHref}
			class="inline-flex items-center gap-1.5 font-mono text-xs text-muted hover:text-amber transition-colors mb-8"
			data-reveal
		>
			<span aria-hidden="true">←</span>
			{t("projects.backToProjects")}
		</a>

		<header class="mb-10" data-reveal data-reveal-delay="80">
			<div class="font-mono text-xs flex items-center gap-3 mb-4 flex-wrap">
				<span class="text-diff-added">+ added</span>
				<span class="text-amber">{project.version}</span>
			</div>
			<h1 class="font-display font-medium text-3xl sm:text-4xl text-primary leading-tight">
				{project.name}
			</h1>
			<p class="text-secondary text-base leading-relaxed mt-4">
				{project.summary}
			</p>
		</header>

		<section class="mb-10" data-reveal data-reveal-delay="140">
			<h2 class="font-mono text-xs text-amber uppercase tracking-wider mb-3">
				{t("projects.details")}
			</h2>
			<p class="text-secondary text-base leading-relaxed">{project.details}</p>
		</section>

		<section class="mb-10" data-reveal data-reveal-delay="200">
			<h2 class="font-mono text-xs text-amber uppercase tracking-wider mb-3">
				{t("projects.techStack")}
			</h2>
			<div class="flex flex-wrap gap-2">
				{
					project.tags.map((tag) => (
						<span class="font-mono text-xs text-muted bg-surface-1 border border-border px-2.5 py-1 rounded-md">
							{tag}
						</span>
					))
				}
			</div>
		</section>

		{
			hasLinks && (
				<section data-reveal data-reveal-delay="260">
					<h2 class="font-mono text-xs text-amber uppercase tracking-wider mb-3">
						{t("projects.links")}
					</h2>
					<div class="flex flex-wrap gap-3">
						{project.links?.demo && (
							<a
								href={project.links.demo}
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex items-center gap-2 font-mono text-sm text-primary border border-border rounded-lg px-4 py-2 hover:border-amber/50 hover:bg-surface-hover transition-colors"
							>
								{t("projects.demo")}
								<span aria-hidden="true">↗</span>
							</a>
						)}
						{project.links?.repo && (
							<a
								href={project.links.repo}
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex items-center gap-2 font-mono text-sm text-primary border border-border rounded-lg px-4 py-2 hover:border-amber/50 hover:bg-surface-hover transition-colors"
							>
								{t("projects.repository")}
								<span aria-hidden="true">↗</span>
							</a>
						)}
					</div>
				</section>
			)
		}

		<ProjectNav currentProject={project} lang={lang} t={t} />
	</article>
</main>
