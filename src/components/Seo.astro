---
import {
	absoluteUrl,
	DEFAULT_OG_IMAGE,
	DEFAULT_OG_IMAGE_ALT,
	DEFAULT_OG_IMAGE_HEIGHT,
	DEFAULT_OG_IMAGE_TYPE,
	DEFAULT_OG_IMAGE_WIDTH,
} from "../lib/seo";
import type { Locale } from "../types/portfolio";

interface Props {
	title: string;
	description?: string;
	lang: Locale;
	path: string;
	canonicalUrl: string;
	alternateUrl: string;
	siteUrl: string;
	image?: string;
	imageAlt?: string;
	ogType?: "website" | "article" | "profile";
	publishedAt?: Date;
	modifiedAt?: Date;
	authorName?: string;
	noindex?: boolean;
	jsonLd?: Record<string, unknown>[];
}

const {
	title,
	description,
	lang,
	canonicalUrl,
	alternateUrl,
	siteUrl,
	image = DEFAULT_OG_IMAGE,
	imageAlt = DEFAULT_OG_IMAGE_ALT,
	ogType = "website",
	publishedAt,
	modifiedAt,
	authorName,
	noindex = false,
	jsonLd = [],
} = Astro.props;

const ogImage = absoluteUrl(siteUrl, image);
const robotsContent = noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large";
const localeTag = lang === "es" ? "es_PE" : "en_US";
---

<meta name="robots" content={robotsContent} />
<meta name="author" content={authorName ?? "Brayan Nuñez"} />
<meta name="theme-color" content="#16181d" />

{description && <meta name="description" content={description} />}

<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang={lang} href={canonicalUrl} />
<link rel="alternate" hreflang={lang === "es" ? "en" : "es"} href={alternateUrl} />
{
	siteUrl && (
		<link rel="alternate" hreflang="x-default" href={`${siteUrl}/es`} />
	)
}

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Brayan Nuñez" />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={localeTag} />
<meta
	property="og:locale:alternate"
	content={lang === "es" ? "en_US" : "es_PE"}
/>
<meta property="og:image" content={ogImage} />
<meta property="og:image:secure_url" content={ogImage} />
<meta property="og:image:type" content={DEFAULT_OG_IMAGE_TYPE} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:image:width" content={String(DEFAULT_OG_IMAGE_WIDTH)} />
<meta property="og:image:height" content={String(DEFAULT_OG_IMAGE_HEIGHT)} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={imageAlt} />

{publishedAt && (
	<meta property="article:published_time" content={publishedAt.toISOString()} />
)}
{modifiedAt && (
	<meta property="article:modified_time" content={modifiedAt.toISOString()} />
)}

<link rel="apple-touch-icon" href="/logo-banp-icon.svg" />

{
	jsonLd.length > 0 && (
		<script
			type="application/ld+json"
			set:html={JSON.stringify(jsonLd.length === 1 ? jsonLd[0] : jsonLd)}
		/>
	)
}
