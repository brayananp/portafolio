---
import { useTranslations } from "../i18n/ui";
import type { Locale, PortfolioData } from "../types/portfolio";
import Header from "./Header.astro";
import About from "./sections/About.astro";
import BlogPreview from "./sections/BlogPreview.astro";
import Career from "./sections/Career.astro";
import Contact from "./sections/Contact.astro";
import Footer from "./sections/Footer.astro";
import Hero from "./sections/Hero.astro";
import Projects from "./sections/Projects.astro";
import Stack from "./sections/Stack.astro";

interface Props {
	lang: Locale;
	portfolio: PortfolioData;
}

const { lang, portfolio } = Astro.props;
const t = useTranslations(lang);
---

<Header lang={lang} />
<main class="flex flex-col gap-20 sm:gap-28 pb-16">
	<Hero
		data={portfolio.hero}
		social={portfolio.social}
		displayName={portfolio.displayName}
		lang={lang}
		t={t}
	/>
	<div data-reveal>
		<Career data={portfolio.career} t={t} />
	</div>
	<Projects data={portfolio.projects} lang={lang} t={t} />
	<div data-reveal data-reveal-delay="80">
		<About data={portfolio.about} t={t} />
	</div>
	<div data-reveal data-reveal-delay="120">
		<Stack stack={portfolio.stack} t={t} />
	</div>
	<div data-reveal data-reveal-delay="160">
		<BlogPreview lang={lang} t={t} />
	</div>
	<div data-reveal data-reveal-delay="200">
		<Contact data={portfolio.contact} t={t} />
	</div>
</main>
	<Footer data={portfolio} lang={lang} t={t} />
