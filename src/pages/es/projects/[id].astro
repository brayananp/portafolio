---
import ProjectDetail from "../../../components/projects/ProjectDetail.astro";
import { portfolio } from "../../../data/portfolio.es";
import { useTranslations } from "../../../i18n/ui";
import Layout from "../../../layouts/Layout.astro";
import { getProjectPath } from "../../../lib/projects";
import {
	absoluteUrl,
	buildBreadcrumbJsonLd,
	buildSoftwareProjectJsonLd,
	getSiteUrl,
} from "../../../lib/seo";

export function getStaticPaths() {
	return portfolio.projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const t = useTranslations("es");
const path = getProjectPath("es", project.id);
const siteUrl = getSiteUrl(Astro.site);
const pageUrl = absoluteUrl(siteUrl, path);
const jsonLd = [
	buildSoftwareProjectJsonLd({
		siteUrl,
		name: project.name,
		description: project.summary,
		url: pageUrl,
		tags: project.tags,
		authorName: portfolio.authorName,
	}),
	buildBreadcrumbJsonLd([
		{ name: "Inicio", url: absoluteUrl(siteUrl, "/es") },
		{ name: "Proyectos", url: `${absoluteUrl(siteUrl, "/es")}#projects` },
		{ name: project.name, url: pageUrl },
	]),
];
---

<Layout
	title={`${project.name} — ${portfolio.hero.role}`}
	description={project.summary}
	lang="es"
	path={path}
	authorName={portfolio.authorName}
	jsonLd={jsonLd}
>
	<ProjectDetail project={project} lang="es" t={t} />
</Layout>
