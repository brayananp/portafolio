---
import ProjectDetail from "../../../components/projects/ProjectDetail.astro";
import { portfolio } from "../../../data/portfolio.en";
import { useTranslations } from "../../../i18n/ui";
import Layout from "../../../layouts/Layout.astro";
import { getProjectPath } from "../../../lib/projects";

export function getStaticPaths() {
	return portfolio.projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const t = useTranslations("en");
---

<Layout
	title={`${project.name} — Projects`}
	description={project.summary}
	lang="en"
	path={getProjectPath("en", project.id)}
>
	<ProjectDetail project={project} lang="en" t={t} />
</Layout>
